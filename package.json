{
  "name": "dpp",
  "description": "for work.",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "watch:build": "chokidar \"src/**/*\" -c \"wxt build\"",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "prepare": "simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@codingame/monaco-vscode-multi-diff-editor-service-override": "^28.3.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@rrweb/packer": "2.0.0-alpha.20",
    "@rrweb/types": "2.0.0-alpha.20",
    "@tanstack/react-virtual": "^3.13.21",
    "@types/masonry-layout": "^4.2.8",
    "@unocss/preset-icons": "^66.6.0",
    "@unocss/preset-uno": "^66.6.0",
    "@unocss/reset": "^66.6.0",
    "allotment": "^1.20.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color2k": "^2.0.3",
    "date-fns": "^4.1.0",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "diff": "^8.0.3",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.563.0",
    "masonry-layout": "^4.2.2",
    "monaco-editor": "^0.55.1",
    "page-agent": "^1.6.2",
    "react": "^19.2.3",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "unocss": "^66.6.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.0",
    "@types/chrome": "^0.1.37",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.1",
    "vite-plugin-babel": "^1.5.1",
    "wxt": "^0.20.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
